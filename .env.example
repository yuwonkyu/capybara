# Supabase 프로젝트 설정 > API 메뉴에서 확인할 수 있습니다.
# service role key는 절대 공개 저장소에 커밋하지 마세요.
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 카카오 로그인(클라이언트)용 — anon(public) key는 노출되어도 되는 키입니다.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 디스코드 기부현황 자동 수집 (선택) — 설정하지 않으면 동기화 기능만 비활성화됩니다.
# 봇 토큰은 절대 공개 저장소에 커밋하지 마세요.
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_GUILD_ID=your-discord-server-id
DISCORD_CHANNEL_CAPY=capy-invest-channel-id
DISCORD_CHANNEL_CAPYLAND=capyland-invest-channel-id
